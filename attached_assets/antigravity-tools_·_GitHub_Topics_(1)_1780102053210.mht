body { min-height: 100vh; line-height: 1.5; }

a:not([class]) { text-decoration-skip-ink: auto; }

img, picture { max-width: 100%; display: block; }

input, button, textarea, select { font: inherit; }

@media (prefers-reduced-motion: reduce) {
