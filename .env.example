# ─────────────────────────────────────────────────────────────────────────────
# mr7.ai / PentestLab Pro — Environment Variables Reference
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/mr7_ai

# ── Security ──────────────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-string-min-32-chars
INTERNAL_API_KEY=change-this-to-a-secure-random-string
ADMIN_SECRET=CHATGPT-OWNER-2026

# JWT RSA Key Pair (auto-generated on first run if not set)
# JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----...
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----...

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8080
APP_VERSION=1.0.0

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AI Providers ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
PERPLEXITY_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
COHERE_API_KEY=

# Embedding model (default: text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small

# ── Redis (optional — in-memory fallback if not set) ──────────────────────────
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://user:password@redis-host:6380  # TLS

# ── SMTP Email (optional — console log fallback if not set) ───────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@mr7.ai
# EMAIL_FROM_NAME=mr7.ai

# ── OAuth — Google (optional) ─────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── OAuth — GitHub (optional) ─────────────────────────────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── File Storage ──────────────────────────────────────────────────────────────
# STORAGE_PROVIDER=local     # "local" | "s3"
# LOCAL_UPLOAD_DIR=./uploads
# MAX_UPLOAD_SIZE=52428800   # 50MB in bytes

# S3 / Cloudflare R2 (required when STORAGE_PROVIDER=s3)
# S3_BUCKET_NAME=
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=               # Cloudflare R2: https://<account>.r2.cloudflarestorage.com
# S3_PUBLIC_URL=             # Custom domain for public file access

# ── pgvector — Semantic Search & RAG ─────────────────────────────────────────
# Automatically enabled when the pgvector PostgreSQL extension is available.
# Run in psql: CREATE EXTENSION IF NOT EXISTS vector;

# ── Sentry Error Tracking (optional) ─────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ── OpenTelemetry Tracing (optional) ─────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=mr7ai-api

# ── Backup Scheduler (optional) ───────────────────────────────────────────────
# BACKUP_ENABLED=false
# BACKUP_DIR=./backups
# BACKUP_KEEP_DAYS=30
# BACKUP_SCHEDULE=daily      # "hourly" | "daily" | "weekly"

# ── Security Report Webhook ───────────────────────────────────────────────────
# SECURITY_REPORT_WEBHOOK_URL=https://hooks.slack.com/...

# ── Stripe (optional) ────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO=price_...
# STRIPE_PRICE_ID_ENTERPRISE=price_...

# ── Replit Auth (auto-configured on Replit) ───────────────────────────────────
# REPL_ID=                   # auto-set by Replit
# ISSUER_URL=                # auto-set by Replit

# ── Feature Flags (override any flag via env: FEATURE_<NAME>=true/false) ──────
# FEATURE_OAUTH_GOOGLE=false
# FEATURE_OAUTH_GITHUB=false
# FEATURE_EMAIL_VERIFICATION=false
# FEATURE_VECTOR_SEARCH=true
# FEATURE_FILE_UPLOADS=true
# FEATURE_WEBHOOKS=true
# FEATURE_PENTEST_LAB=true
# FEATURE_COUNCIL_MODE=true
# FEATURE_MARKETPLACE=true
# FEATURE_TEAMS=true
# FEATURE_BACKUP_SCHEDULER=false
# FEATURE_SENTRY=false
# FEATURE_RATE_LIMIT_REDIS=false

# ── OSINT Intelligence APIs ───────────────────────────────────────────────────
# Have I Been Pwned — Email breach lookup
# Get key: https://haveibeenpwned.com/API/Key (affordable for researchers)
# HIBP_API_KEY=

# Hunter.io — Email verification & pattern lookup
# Get key: https://hunter.io (free: 25 requests/month)
# HUNTER_API_KEY=

# AbuseIPDB — IP reputation & abuse reports
# Get key: https://abuseipdb.com (free: 1,000 requests/day)
# ABUSEIPDB_API_KEY=

# VirusTotal — File hash & malware analysis
# Get key: https://virustotal.com (free: 500 requests/day)
# VT_API_KEY=

# Numverify — Phone number validation & carrier lookup
# Get key: https://numverify.com (free: 100 requests/month)
# NUMVERIFY_API_KEY=

# ── PentestLab Pro (Python Flask) ─────────────────────────────────────────────
FLASK_SECRET_KEY=change-this-flask-secret-key
# PENTEST_LAB_PORT=5000
# FAISS_INDEX_PATH=./data/faiss_index

# ── Local AI Models (Ollama) ──────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
