{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [{ "builtIn": 1, "datasource": "-- Grafana --", "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" }] },
  "description": "MR7.AI / KaliGPT Platform Overview Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "API Server",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "API Server Status",
      "type": "stat",
      "targets": [{ "datasource": "Prometheus", "expr": "up{job=\"mr7-api\"}", "legendFormat": "API" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Request Rate",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(http_requests_total{job=\"mr7-api\"}[5m])", "legendFormat": "{{method}} {{route}}" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 1 },
      "id": 3,
      "title": "API Latency (p50/p95/p99)",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"mr7-api\"}[5m]))", "legendFormat": "p50" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"mr7-api\"}[5m]))", "legendFormat": "p95" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"mr7-api\"}[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "AI Inference",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 10,
      "title": "AI Token Throughput (tokens/s)",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(vllm:prompt_tokens_total[5m])", "legendFormat": "vLLM Input" },
        { "datasource": "Prometheus", "expr": "rate(vllm:generation_tokens_total[5m])", "legendFormat": "vLLM Output" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 11,
      "title": "Inference Latency",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.50, rate(vllm:e2e_request_latency_seconds_bucket[5m]))", "legendFormat": "vLLM p50" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.95, rate(vllm:e2e_request_latency_seconds_bucket[5m]))", "legendFormat": "vLLM p95" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "System Resources",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 20,
      "title": "CPU Usage",
      "type": "timeseries",
      "targets": [{ "datasource": "Prometheus", "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{instance}}" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 21,
      "title": "Memory Usage",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "Used" },
        { "datasource": "Prometheus", "expr": "node_memory_MemTotal_bytes", "legendFormat": "Total" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "binBps" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 22,
      "title": "Network I/O",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(node_network_receive_bytes_total[5m])", "legendFormat": "In {{device}}" },
        { "datasource": "Prometheus", "expr": "rate(node_network_transmit_bytes_total[5m])", "legendFormat": "Out {{device}}" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103,
      "title": "Security",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 28 },
      "id": 30,
      "title": "Prompt Injections Blocked",
      "type": "stat",
      "targets": [{ "datasource": "Prometheus", "expr": "increase(mr7_security_prompt_injections_blocked_total[1h])", "legendFormat": "Last 1h" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 28 },
      "id": 31,
      "title": "Rate Limit Blocks",
      "type": "stat",
      "targets": [{ "datasource": "Prometheus", "expr": "increase(mr7_ratelimit_blocked_total[1h])", "legendFormat": "Last 1h" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["mr7-ai", "kaligpt", "overview"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": "Prometheus",
        "definition": "label_values(up, instance)",
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "name": "instance",
        "options": [],
        "query": { "query": "label_values(up, instance)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "type": "query",
        "label": "Instance"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "MR7.AI Platform Overview",
  "uid": "mr7-ai-overview",
  "version": 1
}
