modules = ["nodejs-20", "python-3.11", "web"]
[agent]
expertMode = true
stack = "FLASK_VANILLA_JS"
integrations = ["javascript_openai_ai_integrations:2.0.0", "javascript_anthropic_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"
packages = ["cacert", "cargo", "freetype", "glibcLocales", "iana-etc", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "openssl", "pkg-config", "postgresql", "rustc", "tcl", "tk", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PentestLab Pro"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PentestLab Frontend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/mr7-ai && PORT=5000 BASE_PATH=/ pnpm dev"
waitForPort = 5000

[[workflows.workflow]]
name = "PentestLab Pro"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd pentest-lab/backend && PYTHONPATH=. /home/runner/workspace/.pythonlibs/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && PORT=8080 pnpm dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "PentestLab Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd pentest-lab/frontend && node_modules/.bin/vite --port 3000 --host 0.0.0.0"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[userenv]

[userenv.shared]
NODE_ENV = "development"
PORT = "8080"
APP_URL = "https://${REPLIT_DEV_DOMAIN}"
FRONTEND_URL = "https://${REPLIT_DEV_DOMAIN}"
API_BASE_URL = "https://${REPLIT_DEV_DOMAIN}"
ALLOWED_ORIGINS = "https://${REPLIT_DEV_DOMAIN}"
APP_VERSION = "1.0.0"
STORAGE_PROVIDER = "local"
LOCAL_UPLOAD_DIR = "./uploads"

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:5000", "main:app"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 22938
externalPort = 3001
